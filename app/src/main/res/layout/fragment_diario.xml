<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── HEADER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIÁRIO DE EXECUÇÃO"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:textColor="@color/on_secondary_container"
                    android:background="@drawable/bg_diario_chip"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/tv_data_execucao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:textColor="@color/outline"
                    android:textAllCaps="true" />
            </LinearLayout>

            <!-- Recipe dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_receita"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Receita"
                android:layout_marginBottom="4dp">

                <AutoCompleteTextView
                    android:id="@+id/act_receita"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tentativa subtitle -->
            <TextView
                android:id="@+id/tv_tentativa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecione uma receita para começar"
                android:textSize="14sp"
                android:textColor="@color/on_surface_variant"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="2dp" />

            <!-- ── CLASSIFICAÇÃO ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="6dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CLASSIFICAÇÃO GERAL"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textColor="@color/outline"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/star1"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:text="★"
                                android:textSize="26sp"
                                android:gravity="center"
                                android:textColor="@color/outline_variant"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackgroundBorderless" />

                            <TextView
                                android:id="@+id/star2"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:text="★"
                                android:textSize="26sp"
                                android:gravity="center"
                                android:textColor="@color/outline_variant"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackgroundBorderless" />

                            <TextView
                                android:id="@+id/star3"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:text="★"
                                android:textSize="26sp"
                                android:gravity="center"
                                android:textColor="@color/outline_variant"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackgroundBorderless" />

                            <TextView
                                android:id="@+id/star4"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:text="★"
                                android:textSize="26sp"
                                android:gravity="center"
                                android:textColor="@color/outline_variant"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackgroundBorderless" />

                            <TextView
                                android:id="@+id/star5"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:text="★"
                                android:textSize="26sp"
                                android:gravity="center"
                                android:textColor="@color/outline_variant"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackgroundBorderless" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="48dp"
                        android:background="@color/outline_variant"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_vault_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VAULT SCORE"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:textColor="@color/outline" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── FOTO ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_foto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="6dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp">

                    <ImageView
                        android:id="@+id/iv_foto_execucao"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="Foto da execução" />

                    <LinearLayout
                        android:id="@+id/layout_sem_foto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/surface_variant">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/outline"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOQUE PARA ADICIONAR FOTO"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:textColor="@color/outline"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <!-- Change photo button (visible when photo is set) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_trocar_foto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="10dp"
                        android:text="TROCAR"
                        android:textSize="11sp"
                        android:backgroundTint="@color/primary"
                        app:icon="@drawable/ic_camera"
                        app:iconSize="14dp"
                        android:visibility="gone" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── VARIÁVEIS TÉCNICAS ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="6dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Variáveis Técnicas"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="temperatura • tempo • espessura..."
                            android:textSize="11sp"
                            android:textColor="@color/outline" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/container_variaveis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <Button
                        android:id="@+id/btn_add_variavel"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text="+ Adicionar Variável"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── ANOTAÇÕES DO CHEF ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="6dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Anotações do Chef"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp" />

                    <!-- O que funcionou header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓"
                            android:textSize="15sp"
                            android:textColor="@color/secondary"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="O QUE FUNCIONOU"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:textColor="@color/secondary" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/et_funcionou"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="90dp"
                        android:gravity="top|start"
                        android:background="@drawable/bg_inset_field"
                        android:padding="12dp"
                        android:hint="O que deu certo nessa tentativa..."
                        android:textSize="15sp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:inputType="textMultiLine"
                        android:layout_marginBottom="16dp" />

                    <!-- Pontos de melhoria header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↑"
                            android:textSize="15sp"
                            android:textColor="@color/surface_tint"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PONTOS DE MELHORIA"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:textColor="@color/surface_tint" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/et_melhoria"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="100dp"
                        android:gravity="top|start"
                        android:background="@drawable/bg_inset_field"
                        android:padding="12dp"
                        android:hint="O que pode melhorar na próxima tentativa..."
                        android:textSize="15sp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:inputType="textMultiLine" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── EVOLUÇÃO ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Evolução"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:id="@+id/container_evolucao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/tv_sem_historico"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Selecione uma receita para ver o histórico"
                        android:textSize="13sp"
                        android:textColor="@color/outline"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── SALVAR ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_salvar_registro"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="SALVAR REGISTRO"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:backgroundTint="@color/primary"
                android:textColor="@color/on_primary"
                android:layout_marginBottom="8dp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconSize="18dp"
                app:iconGravity="textStart" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
