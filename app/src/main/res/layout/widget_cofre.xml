<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_container"
    android:orientation="vertical"
    android:padding="12dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cofre Gastronômico"
        android:textColor="@color/primary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:id="@+id/widget_active_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_timer_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_timer_remaining"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="@color/primary_container"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_idle_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nenhum timer ativo"
        android:textColor="@color/outline"
        android:textSize="12sp"
        android:visibility="visible" />

</LinearLayout>
