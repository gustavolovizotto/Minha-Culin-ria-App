<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/acervoFragment">

    <fragment
        android:id="@+id/acervoFragment"
        android:name="com.example.minhaculinriaapp.ui.acervo.AcervoFragment"
        android:label="@string/nav_acervo">
        <action
            android:id="@+id/action_acervo_to_cadastro_receita"
            app:destination="@id/cadastroReceitaStep1Fragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_acervo_to_cadastro_categoria"
            app:destination="@id/cadastroCategoriaFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_acervo_to_detalhes_receita"
            app:destination="@id/detalhesReceitaFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/detalhesReceitaFragment"
        android:name="com.example.minhaculinriaapp.ui.detalhes.DetalhesReceitaFragment"
        android:label="Detalhes da Receita">
        <argument
            android:name="receitaId"
            app:argType="long" />
        <action
            android:id="@+id/action_detalhes_to_maos_massa"
            app:destination="@id/maosNaMassaFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/maosNaMassaFragment"
        android:name="com.example.minhaculinriaapp.ui.execucao.MaosNaMassaFragment"
        android:label="@string/nav_maos_massa">
        <argument
            android:name="receitaId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/diarioFragment"
        android:name="com.example.minhaculinriaapp.ui.diario.DiarioFragment"
        android:label="@string/nav_diario" />

    <fragment
        android:id="@+id/perfilFragment"
        android:name="com.example.minhaculinriaapp.ui.perfil.PerfilFragment"
        android:label="@string/nav_perfil" />

    <!-- Cadastro de Receita: 3 steps -->
    <fragment
        android:id="@+id/cadastroReceitaStep1Fragment"
        android:name="com.example.minhaculinriaapp.ui.cadastro.CadastroReceitaStep1Fragment"
        android:label="Nova Receita — Passo 1">
        <action
            android:id="@+id/action_step1_to_step2"
            app:destination="@id/cadastroReceitaStep2Fragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_step1_to_cadastro_categoria"
            app:destination="@id/cadastroCategoriaFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/cadastroReceitaStep2Fragment"
        android:name="com.example.minhaculinriaapp.ui.cadastro.CadastroReceitaStep2Fragment"
        android:label="Nova Receita — Passo 2">
        <action
            android:id="@+id/action_step2_to_step3"
            app:destination="@id/cadastroReceitaStep3Fragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/cadastroReceitaStep3Fragment"
        android:name="com.example.minhaculinriaapp.ui.cadastro.CadastroReceitaStep3Fragment"
        android:label="Nova Receita — Passo 3">
        <action
            android:id="@+id/action_step3_to_acervo"
            app:destination="@id/acervoFragment"
            app:popUpTo="@id/acervoFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_left"
            app:exitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Cadastro de Categoria -->
    <fragment
        android:id="@+id/cadastroCategoriaFragment"
        android:name="com.example.minhaculinriaapp.ui.cadastro.CadastroCategoriaFragment"
        android:label="Nova Categoria" />

</navigation>
